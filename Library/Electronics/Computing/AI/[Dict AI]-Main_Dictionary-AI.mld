                        {"name": "Moderate", "desc": "Multi-step reasoning or technical drafting.", "example": "Generate a TypeScript interface for a user profile object."},
                        {"name": "Hard", "desc": "Context-heavy tasks involving multi-file analysis or debugging.", "example": "Fixing a circular dependency in a large React project via Cursor."},
                        {"name": "Expert", "desc": "Autonomous agent management and deep technical troubleshooting.", "example": "Using Cline to execute terminal commands and fix build errors."}
