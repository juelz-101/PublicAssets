                        {"name": "Cursor", "others": ["AI Code Editor"], "category": "Development", "sub": "IDEs", "definition": "A fork of VS Code with deep codebase-indexing and AI-native editing features.", "example": "Refactoring an entire folder of code with a single prompt.", "level": 4, "difficulty": 4},
